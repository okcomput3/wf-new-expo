+    float calculate_close_z()
+    {
+        // The projection uses aspect=1.0.  output_transform then maps the
+        // square NDC space onto the physical framebuffer (which is NOT square).
+        // So to fill the screen exactly we must satisfy both axes:
+        //
+        //   Z_height = (PANEL_SCALE/2) / tan(fov/2)          (fills height)
+        //   Z_width  = (PANEL_SCALE/2) / (tan(fov/2)*aspect) (fills width)
+        //
+        // For landscape (aspect>1): Z_width < Z_height, so Z_width is the
+        // binding constraint — use it so neither axis overflows.
+        float half_fov  = glm::radians(22.5f);
+        float tan_hfov  = std::tan(half_fov);
+        auto  og        = output->get_layout_geometry();
+        float aspect    = (float)og.width / (float)og.height;
+        float z_height  = (PANEL_SCALE * 0.5f) / tan_hfov;
+        float z_width   = (PANEL_SCALE * 0.5f) / (tan_hfov * aspect);
+        return std::min(z_height, z_width);   // exact fit, no fudge factor
+    }